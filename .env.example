# ------------------------------
# Required credentials
# ------------------------------
OPENAI_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SUPABASE_DB_URL=

# Recommended for strict webhook verification
TWILIO_WEBHOOK_URL=

# Optional caregiver/public links
CAREGIVER_PHONE_NUMBER=
DASHBOARD_PUBLIC_URL=

# ------------------------------
# Runtime tuning
# ------------------------------
DB_CONNECT_TIMEOUT_SECONDS=10
MEDIA_DOWNLOAD_TIMEOUT_SECONDS=20
DIALOGUE_CONTEXT_TURNS=3
LOG_SENSITIVE_DATA=false

ENABLE_SUMMARY_REPAIR=true
SUMMARY_REPAIR_MAX_ATTEMPTS=1
HIGH_RISK_SCORE_THRESHOLD=4

ENABLE_PROACTIVE_CHECKIN=true
PROACTIVE_INTERVAL_MINUTES=60
PROACTIVE_CHECKIN_TIMEZONE=Europe/London

SCHEDULER_REQUIRE_LEADER_LOCK=true
SCHEDULER_LEADER_PORT=47200
SCHEDULER_EXECUTION_LOCK_ENABLED=true
SCHEDULER_EXECUTION_LOCK_NAME=proactive_clinical_checkin
SCHEDULER_EXECUTION_LOCK_OWNER=
SCHEDULER_EXECUTION_LOCK_TTL_SECONDS=3600

ENABLE_TWILIO_SIGNATURE_VALIDATION=true
CAREGIVER_CONTEXT_LOG_LIMIT=10

# ------------------------------
# Dashboard authentication
# ------------------------------
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
# Optional stronger auth with SHA-256 hash of password.
# If set, hash mode is enforced and DASHBOARD_PASSWORD is ignored.
DASHBOARD_PASSWORD_HASH=
DASHBOARD_REQUIRE_AUTH=true
DASHBOARD_SESSION_TIMEOUT_MINUTES=60
DASHBOARD_LOOKBACK_DAYS=365
DASHBOARD_HISTORY_LIMIT=5000

# ------------------------------
# Local server options
# ------------------------------
PORT=5000
FLASK_DEBUG=false
